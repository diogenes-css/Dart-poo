6. Exercício 

Crie uma classe Curso com:

nome
cargaHoraria
professor


Código da Aula:

class Aluno {
  String nome;
  int idade;
  String curso;
  Aluno(this.nome, this.idade, this.curso);
  void apresentar() {
    print('Nome: $nome');
    print('Idade: $idade');
    print('Curso: $curso');
    print('--------------------');
  }
}
void main() {
  Aluno aluno1 = Aluno('Ana', 16, 'Desenvolvimento de Sistemas');
  Aluno aluno2 = Aluno('Bruno', 17, 'Informática');
  Aluno aluno3 = Aluno('Carla', 16, 'Redes de Computadores');
  aluno1.apresentar();
  aluno2.apresentar();
  aluno3.apresentar();
}